rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Adjuntos de solicitudes de reembolso — solo usuarios autenticados
    match /reimbursements/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Comprobantes de pago — solo usuarios autenticados
    match /vouchers/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}