// GMT Link — Esquema núcleo (plan maestro §4.2, verbatim).
// Postgres = datos de negocio + catálogo legible de roles/permisos (espejo de OpenFGA, §4.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ IDENTIDAD ============
model User {
  id                     String                    @id @default(cuid())
  firstName              String
  secondName             String?
  lastName               String
  secondLastName         String?
  email                  String                    @unique // compat (§4.1 D1): siempre poblado = emailInstitucional ?? emailPersonal
  username               String                    @unique // login por username (default = prefijo del email institucional)
  emailInstitucional     String?                   @unique // uno de {emailInstitucional, emailPersonal} obligatorio
  emailPersonal          String?
  avatarUrl              String?
  passwordHash           String? // hash bcrypt de la contraseña; null hasta que el usuario fija su clave
  status                 UserStatus                @default(PENDING_FIRST_LOGIN)
  points                 Int                       @default(0) // gamificación
  isClientUser           Boolean                   @default(false)
  clientId               String?
  client                 Client?                   @relation(fields: [clientId], references: [id])
  memberships            Membership[]
  cv                     CV?
  documents              PersonalDocument[]        @relation("UserDocuments")
  reviewedDocs           PersonalDocument[]        @relation("DocumentReviewer")
  dashboard              DashboardConfig?
  preferences            UserPreferences?
  notifications          Notification[]            @relation("UserNotifications")
  permissionRequests     PermissionRequest[]       @relation("RequestedBy")
  decidedRequests        PermissionRequest[]       @relation("DecidedBy")
  reimbursements         Reimbursement[]           @relation("ReimbursementRequester")
  approvedReimbursements Reimbursement[]           @relation("ReimbursementApprover")
  overtimeRequests       OvertimeRequest[]         @relation("OvertimeRequester")
  approvedOvertime       OvertimeRequest[]         @relation("OvertimeApprover")
  overtimeOnBehalf       OvertimeRequest[]         @relation("OvertimeOnBehalf")
  overtimeAuthorized     OvertimeRequest[]         @relation("OvertimeAuthorizer")
  liquidations           Liquidation[]             @relation("UserLiquidations")
  tasksAssigned          Task[]                    @relation("TaskAssignee")
  tasksCreated           Task[]                    @relation("TaskCreator")
  clientTasksRequested   Task[]                    @relation("TaskClientRequester")
  projectDocuments       ProjectDocument[]         @relation("ProjectDocumentOwner")
  signedQADocs           ProjectDocument[]         @relation("DocumentQASigner")
  signedClientDocs       ProjectDocument[]         @relation("DocumentClientSigner")
  assignedAssets         Asset[]                   @relation("AssignedAssets")
  inUseAssets            Asset[]                   @relation("InUseAssets")
  reviewedAssetDocs      AssetDocument[]           @relation("AssetDocReviewer")
  assetHistoryEntries    AssetHistoryEntry[]       @relation("AssetHistoryActor")
  reviewedChecklists     ChecklistTemplate[]       @relation("ChecklistReviewer")
  submittedChecklists    ChecklistSubmission[]     @relation("ChecklistSubmitter")
  providerRatings        ProviderRating[]          @relation("ProviderRatingActor")
  warehouseTransactions  WarehouseTransaction[]    @relation("WarehouseTransactionActor")
  geminiUsages           GeminiUsage[]             @relation("GeminiUsageActor")
  pointsLogs             PointsLog[]               @relation("PointsLogUser")
  achievements           UserAchievement[]         @relation("UserAchievements")
  dataPointsCreated      DataPoint[]               @relation("DataPointCreator")
  faenasSupervised       Faena[]                   @relation("FaenaSupervisor")
  projectsAdmin          Project[]                 @relation("ProjectAdmin")
  projectAssignments     ProjectWorkerAssignment[] @relation("ProjectAssignments")
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
}

enum UserStatus {
  PENDING_FIRST_LOGIN
  ACTIVE
  SUSPENDED
}

// ============ ORGANIZACIÓN ============
model Client {
  id       String    @id @default(cuid())
  code     String    @unique // máx 4 chars — obligatorio en codificación (§7)
  name     String
  rut      String?
  users    User[]
  projects Project[]
  faenas   Faena[]
}

// ============ FAENA (agrupador de proyectos por cliente) ============
model Faena {
  id           String      @id @default(cuid())
  code         String
  name         String
  clientId     String
  client       Client      @relation(fields: [clientId], references: [id])
  supervisorId String?
  supervisor   User?       @relation("FaenaSupervisor", fields: [supervisorId], references: [id])
  status       FaenaStatus @default(PLANIFICADA)
  startDate    DateTime?
  endDate      DateTime?
  projects     Project[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([clientId, code])
}

model Department {
  id       String    @id @default(cuid())
  code     String    @unique // 3 chars
  name     String
  projects Project[]
}

model Project {
  id             String                    @id @default(cuid())
  code           String // 3 chars, único dentro del depto
  name           String
  description    String?
  departmentId   String
  department     Department                @relation(fields: [departmentId], references: [id])
  clientId       String
  client         Client                    @relation(fields: [clientId], references: [id])
  contractNumber String?
  projectType    ProjectType?
  faenaId        String?
  faena          Faena?                    @relation(fields: [faenaId], references: [id])
  projectAdminId String?
  projectAdmin   User?                     @relation("ProjectAdmin", fields: [projectAdminId], references: [id])
  workers        ProjectWorkerAssignment[]
  services       Service[]
  kpis           Json?
  tasks          Task[]
  documents      ProjectDocument[]
  assets         Asset[]                   @relation("ProjectAssets")
  elements       Element[]                 @relation("ProjectElements")
  overtimeRequests OvertimeRequest[]       @relation("OvertimeProject")
  createdAt      DateTime                  @default(now())

  @@unique([departmentId, code])
}

// ============ ASIGNACIÓN DE TRABAJADORES A PROYECTO ============
model ProjectWorkerAssignment {
  id        String              @id @default(cuid())
  projectId String
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation("ProjectAssignments", fields: [userId], references: [id])
  roleKey   String
  status    ProjectWorkerStatus @default(ACTIVO)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime            @default(now())

  @@unique([projectId, userId, roleKey])
}

model Service {
  id              String            @id @default(cuid())
  code            String // 3 chars
  name            String
  projectId       String
  project         Project           @relation(fields: [projectId], references: [id])
  frequency       ServiceFrequency?
  docCodingConfig Json
  tasks           Task[]
  documents       ProjectDocument[]
  phases          Phase[]           @relation("ServicePhases")

  @@unique([projectId, code])
}

// ============ ROLES Y PERMISOS (catálogo — espejo de OpenFGA) ============
model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  description String?
  isSystem    Boolean          @default(false) // rol sembrado (estructural/SuperAdmin): no editable/borrable por admin
  createdById String? // quién lo creó (null = semilla del sistema)
  permissions RolePermission[]
  memberships Membership[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  module      String           @default("system") // agrupador de la matriz UI (Módulo 4)
  kind        PermissionKind   @default(FUNCTIONAL) // FUNCTIONAL = filtro de datos; STRUCTURAL = relación FGA
  fgaRelation String? // si STRUCTURAL: relación FGA a consultar
  scopeable   Boolean          @default(true) // false = sin selector de scope (siempre GLOBAL)
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  scope        PermissionScope @default(PROJECT) // "Solo propios / Proyecto / Todo" de la matriz (ADR-0001)
  role         Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Membership {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  roleKey   String
  // FK a Role.key (unique) con Restrict: cierra la carrera count→delete de
  // RolesService.deleteRole (review Task 2.10) — borrar un Role con
  // memberships revienta con P2003 en vez de dejar roleKeys colgados.
  role      Role      @relation(fields: [roleKey], references: [key], onDelete: Restrict)
  scopeType ScopeType
  scopeId   String
  createdAt DateTime  @default(now())

  @@unique([userId, roleKey, scopeType, scopeId])
}

enum ScopeType {
  ORGANIZATION
  DEPARTMENT
  PROJECT
  SERVICE
}

// Alcance de un permiso dentro de un rol (Módulo 4, ADR-0001).
enum PermissionScope {
  OWN // Solo propios — predicado SQL createdById = userId
  PROJECT // Solo proyectos asociados — membresía vía FGA/Membership
  GLOBAL // Todo / org-wide
}

// Cómo se enforcea un permiso: filtro de datos (FUNCTIONAL) vs. relación FGA (STRUCTURAL).
enum PermissionKind {
  FUNCTIONAL
  STRUCTURAL
}

// ============ PERFIL — CV (§6-1.4) ============
// CV 1:1 con User; tres arrays editables (experiencia / educación / certificaciones).
model CV {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences    CVExperience[]
  education      CVEducation[]
  certifications CVCertification[]

  @@map("cvs")
}

model CVExperience {
  id          String    @id @default(cuid())
  cvId        String
  cv          CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  role        String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())

  @@map("cv_experiences")
}

model CVEducation {
  id          String    @id @default(cuid())
  cvId        String
  cv          CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  @@map("cv_education")
}

model CVCertification {
  id        String    @id @default(cuid())
  cvId      String
  cv        CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  name      String
  issuer    String?
  issuedAt  DateTime?
  expiresAt DateTime?
  fileUrl   String? // diploma PDF (StorageService; stub local en dev)
  createdAt DateTime  @default(now())

  @@map("cv_certifications")
}

// ============ PERFIL — Documentos personales (§6-1.5) ============
// Versionado vía la primitiva ApprovalWorkflow: status + versión anterior + revisor.
model PersonalDocument {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  type            String
  name            String
  fileUrl         String
  issuedAt        DateTime?
  expiresAt       DateTime? // para alertas de vencimiento
  status          DocumentStatus @default(EN_REVISION)
  previousFileUrl String? // versión anterior conservada al subir una nueva
  reviewedById    String?
  reviewedBy      User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("personal_documents")
}

enum DocumentStatus {
  BORRADOR
  EN_REVISION
  APROBADO
  RECHAZADO
}

// ============ DASHBOARD (§6-2.1) ============
// Layout modular configurable por usuario. `layout` es JSONB: lista de
// { widgetKey, order, visible } que el frontend acomoda y persiste.
model DashboardConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt

  @@map("dashboard_configs")
}

// ============ NOTIFICACIONES (§6-2.2) ============
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

// ============ CONFIGURACIÓN (§6-2.3) ============
model UserPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme       String   @default("system") // system | light | dark
  notifyInApp Boolean  @default(true)
  notifyEmail Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("user_preferences")
}

// Solicitud de un rol/permiso a un admin (§6-2.3 "solicitar permisos a admin").
model PermissionRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("RequestedBy", fields: [userId], references: [id], onDelete: Cascade)
  roleKey     String
  scopeType   ScopeType
  scopeId     String
  reason      String?
  status      RequestStatus @default(PENDIENTE)
  decidedById String?
  decidedBy   User?         @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())

  @@index([status])
  @@map("permission_requests")
}

enum RequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

// ============ FINANZAS (Etapa 3) ============
// Estado comun de solicitudes financieras (reembolsos, horas extra).
enum FinanceStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
  PAGADO
}

// Reembolso (§6-3.1/3.2). monto en CLP entero (sin decimales).
model Reimbursement {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation("ReimbursementRequester", fields: [userId], references: [id], onDelete: Cascade)
  amount          Int
  date            DateTime
  concept         String
  category        String? // Alimentación | Transporte | Vehículos | Otro(s)
  subcategory     String? // solo Vehículos: Combustible | Mantención-Limpieza | Repuesto | Otro
  vehicle         String? // id/etiqueta de vehículo cuando category = Vehículos
  observations    String? // observaciones opcionales del solicitante
  receiptUrl      String? // URL de descarga de la boleta (en R2, firmada y efímera)
  receiptKey      String? // clave ESTABLE del storage para leer la boleta (impresión en lote)
  status          FinanceStatus @default(PENDIENTE)
  rejectionReason String? // motivo persistido cuando status = RECHAZADO
  printed         Boolean       @default(false) // marcada como impresa en un lote
  printedAt       DateTime? // cuándo se marcó impresa
  decidedById     String?
  decidedBy       User?         @relation("ReimbursementApprover", fields: [decidedById], references: [id])
  decidedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@map("reimbursements")
}

// Horas extra (§6-3.3). Reusa el patron de reembolsos.
model OvertimeRequest {
  id               String        @id @default(cuid())
  userId           String // DUEÑO: el trabajador cuyas horas son
  user             User          @relation("OvertimeRequester", fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime
  startTime        String? // "HH:mm" hora inicio (obligatoria al crear; nullable por filas legacy)
  endTime          String? // "HH:mm" hora término; null => borrador
  hours            Float? // computada de start/end; null mientras es borrador
  isDraft          Boolean       @default(false)
  reason           String? // opcional (el nuevo form no lo pide; legacy)
  projectId        String?
  project          Project?      @relation("OvertimeProject", fields: [projectId], references: [id])
  projectOther     String? // texto libre cuando se elige "Otro"
  authorizedById   String? // "Autorizado por" (admin_contrato / gerencias)
  authorizedBy     User?         @relation("OvertimeAuthorizer", fields: [authorizedById], references: [id])
  onBehalfOfUserId String? // quién la registró a nombre del dueño; null si la creó el propio trabajador
  onBehalfOfUser   User?         @relation("OvertimeOnBehalf", fields: [onBehalfOfUserId], references: [id])
  status           FinanceStatus @default(PENDIENTE)
  rejectionReason  String? // motivo persistido cuando status = RECHAZADO
  decidedById      String?
  decidedBy        User?         @relation("OvertimeApprover", fields: [decidedById], references: [id])
  decidedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId, status])
  @@map("overtime_requests")
}

// Liquidacion de sueldo (§6-3.4). Una por colaborador y periodo (mes).
model Liquidation {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLiquidations", fields: [userId], references: [id], onDelete: Cascade)
  period       String // "2026-06" (mes)
  fileUrl      String // PDF en StorageService
  uploadedById String?
  createdAt    DateTime @default(now())

  @@unique([userId, period])
  @@index([userId])
  @@map("liquidations")
}

// ============ OPERACIONES (Etapa 4) ============

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  REVISADO
  COMPLETADO
}

model Task {
  id              String        @id @default(cuid())
  name            String
  description     String?
  status          TaskStatus    @default(PENDIENTE)
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedToId    String?
  assignedTo      User?         @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  estimatedPoints Int           @default(0)
  actualPoints    Int?
  recurrence      String? // cron expression para tareas cíclicas
  clientUserId    String? // ITO/cliente que solicitó la tarea
  clientUser      User?         @relation("TaskClientRequester", fields: [clientUserId], references: [id], onDelete: SetNull)
  // Módulo 5 — instancia de ejecución (captura de datos SEPARADA; soft-links opcionales):
  phaseId         String? // contexto de captura (fase/periodo)
  elementId       String? // poza/sector objetivo
  dataSpec        Json? // "datos a obtener" que define el Supervisor (variable codes + labels)
  timeLogs        TaskTimeLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId, status])
  @@index([assignedToId])
  @@map("tasks")
}

// Módulo 5 — registro append-only de inicio/fin de actividad (Operador). Soporta pausas/reanudaciones.
model TaskTimeLog {
  id        String    @id @default(cuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String // el operador que ejecuta
  startedAt DateTime
  endedAt   DateTime? // null = en curso
  note      String?
  createdAt DateTime  @default(now())

  @@index([taskId])
  @@index([userId])
  @@map("task_time_logs")
}

enum ProjectDocumentStatus {
  BORRADOR
  PENDIENTE_QA
  PENDIENTE_CLIENTE
  APROBADO
  RECHAZADO
}

model ProjectDocument {
  id              String                @id @default(cuid())
  name            String
  code            String                @unique // formato: GMT-{Client}-{Depto}-{Project}-{Service}-{TipoDoc}-{Area}-{No}
  fileUrl         String
  fileHash        String? // hash SHA-256 para integridad (FES)
  status          ProjectDocumentStatus @default(BORRADOR)
  version         Int                   @default(0) // rev0 = 0, revA = 1, etc.
  previousFileUrl String?
  projectId       String
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User                  @relation("ProjectDocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  qaSignerId      String?
  qaSigner        User?                 @relation("DocumentQASigner", fields: [qaSignerId], references: [id], onDelete: SetNull)
  qaSignedAt      DateTime?
  clientSignerId  String?
  clientSigner    User?                 @relation("DocumentClientSigner", fields: [clientSignerId], references: [id], onDelete: SetNull)
  clientSignedAt  DateTime?
  rejectionReason String? // motivo de rechazo si aplica
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([projectId, status])
  @@index([serviceId])
  @@map("project_documents")
}

// ============ RECURSOS / ACTIVOS (Etapa 5) ============
// Base reutilizable de Equipo (5.2) y Vehículo (5.3) — primitiva `AssetBase` (§5):
// codificación automática, QR/ficha pública, documentos (ApprovalWorkflow),
// historial y disputa "en uso".

enum AssetType {
  EQUIPO
  VEHICULO
}

enum AssetStatus {
  DISPONIBLE
  EN_USO
  MANTENIMIENTO
  BAJA
  DEFECTUOSO
  NO_DISPONIBLE
}

model Asset {
  id                   String                @id @default(cuid())
  code                 String                @unique // codificación automática; identifica el activo en el QR / ficha pública
  type                 AssetType
  name                 String
  description          String?
  status               AssetStatus           @default(DISPONIBLE)
  // Pertenencia opcional a un proyecto (FGA asset.project → can_view_list / can_create).
  projectId            String?
  project              Project?              @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: SetNull)
  // Responsable que corre el checklist (FGA asset.assigned → can_run_checklist).
  assignedToId         String?
  assignedTo           User?                 @relation("AssignedAssets", fields: [assignedToId], references: [id], onDelete: SetNull)
  // Disputa "en uso": quién lo tiene tomado y desde cuándo.
  inUseById            String?
  inUseBy              User?                 @relation("InUseAssets", fields: [inUseById], references: [id], onDelete: SetNull)
  inUseSince           DateTime?
  // Ancla "Solo propios" (Módulo 4, ADR-0001): quién creó el activo.
  createdById          String?
  // Campos específicos por subtipo (ciclos de carga/calibración en equipos; km/ubicación en vehículos).
  metadata             Json?
  documents            AssetDocument[]
  history              AssetHistoryEntry[]
  accessories          AssetAccessory[]
  checklistTemplate    ChecklistTemplate?
  checklistSubmissions ChecklistSubmission[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([type, status])
  @@map("assets")
}

// Documentos del activo (ApprovalWorkflow §5): versionado + revisor. Reusa
// `DocumentStatus` (BORRADOR/EN_REVISION/APROBADO/RECHAZADO) como los docs personales.
model AssetDocument {
  id              String         @id @default(cuid())
  assetId         String
  asset           Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name            String
  type            String
  fileUrl         String
  status          DocumentStatus @default(EN_REVISION)
  previousFileUrl String?
  reviewedById    String?
  reviewedBy      User?          @relation("AssetDocReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  expirationDate  DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([assetId])
  @@map("asset_documents")
}

// Historial de eventos del activo (creación, asignación, uso/liberación, docs, checklist, cambios de estado).
model AssetHistoryEntry {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        String // CREADO | ASIGNADO | EN_USO | LIBERADO | DOC | CHECKLIST | ESTADO | OTRO
  description String
  actorId     String?
  actor       User?    @relation("AssetHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([assetId, createdAt])
  @@map("asset_history")
}

// Accesorios asociados a un equipo/activo (Etapa 5.2)
model AssetAccessory {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  serialNumber String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([assetId])
  @@map("asset_accessories")
}

// Plantilla de checklist (ApprovalWorkflow §5): versionable + revisor.
model ChecklistTemplate {
  id              String                @id @default(cuid())
  assetId         String                @unique
  asset           Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name            String
  items           Json // array de { id, label, type: 'YES_NO' | 'TEXT' | 'NUMBER', required: boolean }
  status          DocumentStatus        @default(EN_REVISION)
  previousItems   Json? // versión anterior para el ApprovalWorkflow
  reviewedById    String?
  reviewedBy      User?                 @relation("ChecklistReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  submissions     ChecklistSubmission[]

  @@index([assetId])
  @@map("checklist_templates")
}

// Registro de respuestas de un checklist ejecutado
model ChecklistSubmission {
  id         String            @id @default(cuid())
  assetId    String
  asset      Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation("ChecklistSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  answers    Json // array de { itemId, value: string/boolean/number, comment?: string }
  createdAt  DateTime          @default(now())

  @@index([assetId])
  @@map("checklist_submissions")
}

// ============ PROVEEDORES (Etapa 5.5) ============
model Provider {
  id        String            @id @default(cuid())
  rut       String?           @unique
  name      String
  email     String?
  phone     String?
  address   String?
  score     Float             @default(0.0)
  products  ProviderProduct[]
  ratings   ProviderRating[]
  supplies  Supply[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@map("providers")
}

model ProviderProduct {
  id          String   @id @default(cuid())
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Int? // CLP sin decimales
  unit        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("provider_products")
}

model ProviderRating {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  score      Int // 1 a 5
  comment    String?
  actorId    String
  actor      User     @relation("ProviderRatingActor", fields: [actorId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@map("provider_ratings")
}

// ============ INSUMOS (Etapa 5.4) ============
model Supply {
  id           String                 @id @default(cuid())
  code         String                 @unique
  name         String
  description  String?
  category     String?
  unit         String                 @default("unidades")
  providerId   String?
  provider     Provider?              @relation(fields: [providerId], references: [id], onDelete: SetNull)
  stocks       WarehouseStock[]
  transactions WarehouseTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("supplies")
}

// ============ BODEGAS (Etapa 5.6) ============
model Warehouse {
  id           String                 @id @default(cuid())
  code         String                 @unique // máx 4 chars
  name         String
  location     String?
  stocks       WarehouseStock[]
  transactions WarehouseTransaction[]
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("warehouses")
}

model WarehouseStock {
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplyId    String
  supply      Supply    @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  quantity    Float     @default(0)

  @@id([warehouseId, supplyId])
  @@map("warehouse_stocks")
}

model WarehouseTransaction {
  id          String          @id @default(cuid())
  warehouseId String
  warehouse   Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  supplyId    String
  supply      Supply          @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  type        WarehouseTxType
  quantity    Float
  reason      String?
  actorId     String?
  actor       User?           @relation("WarehouseTransactionActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())

  @@map("warehouse_transactions")
}

enum WarehouseTxType {
  ENTRY
  EXIT
}

// ============ IA / USO (Etapa 6.2) ============
model GeminiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("GeminiUsageActor", fields: [userId], references: [id], onDelete: Cascade)
  action    String // "SHORE_DETECTION" | "DATA_CLEANING"
  createdAt DateTime @default(now())

  @@map("gemini_usage")
}

// ============ GAMIFICACIÓN (Etapa 7.1) ============
model PointsLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("PointsLogUser", fields: [userId], references: [id], onDelete: Cascade)
  action    String // e.g. "FIRST_LOGIN", "COMPLETE_CV", "UPLOAD_DOC", "COMPLETE_TASK", etc.
  points    Int
  createdAt DateTime @default(now())

  @@map("points_logs")
}

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserAchievements", fields: [userId], references: [id], onDelete: Cascade)
  achievementKey String // e.g. "first_day", "cv_complete", "warehouse_10", etc.
  unlockedAt     DateTime @default(now())

  @@unique([userId, achievementKey])
  @@map("user_achievements")
}

// ============ METRICS / PROJECTS DATA INTEGRACIÓN ============

model Element {
  id              String      @id @default(cuid())
  code            String      @unique
  name            String
  type            String // "POZA" | "ACOPIO" | "RESERVORIO"
  locationPolygon String? // Contorno en formato WKT o GeoJSON string
  metadata        Json? // Niveles/cotas de referencia estáticas: cota_fondo, cota_segura, etc.
  projectId       String
  project         Project     @relation("ProjectElements", fields: [projectId], references: [id], onDelete: Cascade)
  dataPoints      DataPoint[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("elements")
}

model Phase {
  id         String      @id @default(cuid())
  code       String // e.g. "mayo-2026", "semana-12"
  name       String
  serviceId  String
  service    Service     @relation("ServicePhases", fields: [serviceId], references: [id], onDelete: Cascade)
  variables  Variable[]
  dataPoints DataPoint[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([serviceId, code])
  @@map("phases")
}

model Variable {
  id          String       @id @default(cuid())
  code        String // e.g. "vol_salmuera", "cota_espejo", "dem_file"
  name        String
  description String?
  type        VariableType
  unit        String? // e.g. "m³", "m"
  required    Boolean      @default(false)
  phaseId     String
  phase       Phase        @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  dataPoints  DataPoint[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([phaseId, code])
  @@map("variables")
}

enum VariableType {
  SCALAR
  FILE
  LIST
  ENTERO
  DECIMAL
  BOOLEAN
  METROS
  M3
  TEXTO
  IMAGEN
  PLANO
  POLIGONO
  ORTOFOTO
  PDF
  GEODATA
  OTRO
}

enum ProjectType {
  SPOT
  OBRAS_CIVILES
  RUTINARIO
}

enum FaenaStatus {
  PLANIFICADA
  EN_PROGRESO
  COMPLETADA
}

enum ProjectWorkerStatus {
  ACTIVO
  INACTIVO
}

enum ServiceFrequency {
  DIARIA
  SEMANAL
  QUINCENAL
  MENSUAL
  A_DEMANDA
}

model DataPoint {
  id          String   @id @default(cuid())
  value       String // El valor en formato string (o JSON string si es LIST)
  fileUrl     String? // URL de descarga del archivo si es tipo FILE (almacenamiento asíncrono)
  variableId  String
  variable    Variable @relation(fields: [variableId], references: [id], onDelete: Cascade)
  elementId   String?
  element     Element? @relation(fields: [elementId], references: [id], onDelete: Cascade)
  phaseId     String
  phase       Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation("DataPointCreator", fields: [createdById], references: [id])
  taskId      String? // Módulo 5 — traza OPCIONAL a la Tarea de ejecución (sin FK dura)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("data_points")
}

// OTP de no-repudio para subida de cubicaciones/datos (D3 — reemplaza el Map en memoria).
// codeHash en vez de texto plano; attempts habilita lockout tras intentos fallidos.
model OtpCode {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@map("otp_codes")
}

// ============ V-METRIC — DATA HISTÓRICA (migrada de Firestore) ============
// Tablas standalone: preservan tal cual el export de Firestore de V-Metric.
// NO tienen FKs a modelos GMT; `usuario`/`uid` son identidades históricas de V-Metric,
// NO se relacionan con User. `sourceId` = id de documento Firestore (idempotencia por upsert).
// Los valores numéricos venían como string en Firestore → se parsean a Float al importar.

// Reservorios de V-Metric (Firestore: reservorios/{codigo}).
model VmetricReservorio {
  id           String    @id @default(cuid())
  sourceId     String    @unique // _id de Firestore (== codigo, p.ej. "R2")
  codigo       String
  demBlobPath  String? // dem_blob_path
  demUpdatedAt DateTime? // dem_updated_at
  demFilename  String? // dem_filename
  demUrl       String? // dem_url
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("vmetric_reservorios")
}

// Cubicaciones (cálculos de volumen) de V-Metric (Firestore: cubicaciones/{id}).
model VmetricCubicacion {
  id                   String    @id @default(cuid())
  sourceId             String    @unique // _id de Firestore
  reservorioCodigo     String? // reservorio_codigo
  cotaSal              Float? // cota_sal
  cotaAgua             Float? // cota_agua
  fraccionOcluida      Float? // fraccion_ocluida
  volSalM3             Float? // vol_sal_m3
  volSalmueraLibreM3   Float? // vol_salmuera_libre_m3
  volSalmueraOcluidaM3 Float? // vol_salmuera_ocluida_m3
  volSalmueraTotalM3   Float? // vol_salmuera_total_m3
  areaEspejoM2         Float? // area_espejo_m2
  precisionCeldaM      Float? // precision_celda_m
  origen               String? // origen
  versionModelo        String? // version_modelo
  demFilename          String? // dem_filename
  demIdLocal           Float? // dem_id_local
  usuario              String? // usuario histórico V-Metric (NO FK a User)
  uid                  String? // uid histórico V-Metric (NO FK a User)
  deleted              Boolean   @default(false)
  deletedBy            String? // deleted_by
  deletedAt            DateTime? // deleted_at
  sourceCreatedAt      DateTime? // created_at (de Firestore)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([reservorioCodigo])
  @@map("vmetric_cubicaciones")
}

// DEMs (modelos digitales de elevación) de V-Metric (Firestore: dems/{id}).
// Los .tif ya están en el bucket R2 `vmetric-dems` bajo la key `r2Key` (== blob_path).
model VmetricDem {
  id               String    @id @default(cuid())
  sourceId         String    @unique // _id de Firestore
  reservorioCodigo String? // reservorio_codigo
  archivo          String? // archivo
  r2Key            String? // blob_path == key en R2 (null en DEMs históricos que solo tenían storage_url)
  r2Url            String? // storage_url (URL pública histórica, opcional)
  demId            Float? // dem_id
  drone            String? // drone (metadato opcional presente en algunos DEMs)
  usuario          String? // usuario histórico V-Metric (NO FK a User)
  uid              String? // uid histórico V-Metric (NO FK a User)
  sourceCreatedAt  DateTime? // created_at (de Firestore)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([reservorioCodigo])
  @@map("vmetric_dems")
}

// Cotas de referencia por reservorio (Firestore: cotas_referencia/{id}, p.ej. "R2_cota_sal_ref").
model VmetricCotaReferencia {
  id           String    @id @default(cuid())
  sourceId     String    @unique // _id de Firestore
  reservorio   String? // reservorio
  nombreCota   String? // nombreCota
  valorCota    Float? // valorCota
  operador     String? // operador
  observacion  String? // observacion
  datetimeCota DateTime? // datetimeCota
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([reservorio])
  @@map("vmetric_cotas_referencia")
}
