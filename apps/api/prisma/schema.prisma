// GTM Link — Esquema núcleo (plan maestro §4.2, verbatim).
// Postgres = datos de negocio + catálogo legible de roles/permisos (espejo de OpenFGA, §4.1).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ IDENTIDAD ============
model User {
  id             String     @id @default(cuid())
  firstName      String
  secondName     String?
  lastName       String
  secondLastName String?
  email          String     @unique
  avatarUrl      String?
  status         UserStatus @default(PENDING_FIRST_LOGIN)
  points         Int        @default(0) // gamificación
  isClientUser   Boolean    @default(false)
  clientId       String?
  client         Client?    @relation(fields: [clientId], references: [id])
  memberships    Membership[]
  cv             CV?
  documents      PersonalDocument[] @relation("UserDocuments")
  reviewedDocs   PersonalDocument[] @relation("DocumentReviewer")
  dashboard      DashboardConfig?
  preferences    UserPreferences?
  notifications  Notification[]      @relation("UserNotifications")
  permissionRequests PermissionRequest[] @relation("RequestedBy")
  decidedRequests    PermissionRequest[] @relation("DecidedBy")
  reimbursements        Reimbursement[]   @relation("ReimbursementRequester")
  approvedReimbursements Reimbursement[]  @relation("ReimbursementApprover")
  overtimeRequests      OvertimeRequest[] @relation("OvertimeRequester")
  approvedOvertime      OvertimeRequest[] @relation("OvertimeApprover")
  liquidations          Liquidation[]     @relation("UserLiquidations")
  tasksAssigned         Task[]            @relation("TaskAssignee")
  tasksCreated          Task[]            @relation("TaskCreator")
  clientTasksRequested  Task[]            @relation("TaskClientRequester")
  projectDocuments      ProjectDocument[] @relation("ProjectDocumentOwner")
  signedQADocs          ProjectDocument[] @relation("DocumentQASigner")
  signedClientDocs      ProjectDocument[] @relation("DocumentClientSigner")
  assignedAssets        Asset[]           @relation("AssignedAssets")
  inUseAssets           Asset[]           @relation("InUseAssets")
  reviewedAssetDocs     AssetDocument[]   @relation("AssetDocReviewer")
  assetHistoryEntries   AssetHistoryEntry[] @relation("AssetHistoryActor")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum UserStatus {
  PENDING_FIRST_LOGIN
  ACTIVE
  SUSPENDED
}

// ============ ORGANIZACIÓN ============
model Client {
  id       String    @id @default(cuid())
  code     String    @unique // máx 4 chars — obligatorio en codificación (§7)
  name     String
  rut      String?
  users    User[]
  projects Project[]
}

model Department {
  id       String    @id @default(cuid())
  code     String    @unique // 3 chars
  name     String
  projects Project[]
}

model Project {
  id           String     @id @default(cuid())
  code         String // 3 chars, único dentro del depto
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  services     Service[]
  kpis         Json?
  tasks        Task[]
  documents    ProjectDocument[]
  assets       Asset[]           @relation("ProjectAssets")
  createdAt    DateTime   @default(now())

  @@unique([departmentId, code])
}

model Service {
  id              String  @id @default(cuid())
  code            String // 3 chars
  name            String
  projectId       String
  project         Project @relation(fields: [projectId], references: [id])
  docCodingConfig Json
  tasks           Task[]
  documents       ProjectDocument[]

  @@unique([projectId, code])
}

// ============ ROLES Y PERMISOS (catálogo — espejo de OpenFGA) ============
model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  permissions RolePermission[]
}

model Permission {
  id    String           @id @default(cuid())
  key   String           @unique
  label String
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Membership {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  roleKey   String
  scopeType ScopeType
  scopeId   String
  createdAt DateTime  @default(now())

  @@unique([userId, roleKey, scopeType, scopeId])
}

enum ScopeType {
  ORGANIZATION
  DEPARTMENT
  PROJECT
  SERVICE
}

// ============ PERFIL — CV (§6-1.4) ============
// CV 1:1 con User; tres arrays editables (experiencia / educación / certificaciones).
model CV {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  experiences    CVExperience[]
  education      CVEducation[]
  certifications CVCertification[]

  @@map("cvs")
}

model CVExperience {
  id          String    @id @default(cuid())
  cvId        String
  cv          CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  role        String
  company     String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())

  @@map("cv_experiences")
}

model CVEducation {
  id          String    @id @default(cuid())
  cvId        String
  cv          CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  institution String
  degree      String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())

  @@map("cv_education")
}

model CVCertification {
  id        String    @id @default(cuid())
  cvId      String
  cv        CV        @relation(fields: [cvId], references: [id], onDelete: Cascade)
  name      String
  issuer    String?
  issuedAt  DateTime?
  expiresAt DateTime?
  fileUrl   String? // diploma PDF (StorageService; stub local en dev)
  createdAt DateTime  @default(now())

  @@map("cv_certifications")
}

// ============ PERFIL — Documentos personales (§6-1.5) ============
// Versionado vía la primitiva ApprovalWorkflow: status + versión anterior + revisor.
model PersonalDocument {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  type            String
  name            String
  fileUrl         String
  issuedAt        DateTime?
  expiresAt       DateTime? // para alertas de vencimiento
  status          DocumentStatus @default(EN_REVISION)
  previousFileUrl String? // versión anterior conservada al subir una nueva
  reviewedById    String?
  reviewedBy      User?          @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("personal_documents")
}

enum DocumentStatus {
  BORRADOR
  EN_REVISION
  APROBADO
  RECHAZADO
}

// ============ DASHBOARD (§6-2.1) ============
// Layout modular configurable por usuario. `layout` es JSONB: lista de
// { widgetKey, order, visible } que el frontend acomoda y persiste.
model DashboardConfig {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt

  @@map("dashboard_configs")
}

// ============ NOTIFICACIONES (§6-2.2) ============
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}

// ============ CONFIGURACIÓN (§6-2.3) ============
model UserPreferences {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme       String   @default("system") // system | light | dark
  notifyInApp Boolean  @default(true)
  notifyEmail Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  @@map("user_preferences")
}

// Solicitud de un rol/permiso a un admin (§6-2.3 "solicitar permisos a admin").
model PermissionRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("RequestedBy", fields: [userId], references: [id], onDelete: Cascade)
  roleKey     String
  scopeType   ScopeType
  scopeId     String
  reason      String?
  status      RequestStatus @default(PENDIENTE)
  decidedById String?
  decidedBy   User?         @relation("DecidedBy", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())

  @@index([status])
  @@map("permission_requests")
}

enum RequestStatus {
  PENDIENTE
  APROBADA
  RECHAZADA
}

// ============ FINANZAS (Etapa 3) ============
// Estado comun de solicitudes financieras (reembolsos, horas extra).
enum FinanceStatus {
  PENDIENTE
  APROBADO
  RECHAZADO
  PAGADO
}

// Reembolso (§6-3.1/3.2). monto en CLP entero (sin decimales).
model Reimbursement {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("ReimbursementRequester", fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  date        DateTime
  concept     String
  category    String?
  receiptUrl  String? // boleta/comprobante (StorageService)
  status      FinanceStatus @default(PENDIENTE)
  decidedById String?
  decidedBy   User?         @relation("ReimbursementApprover", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, status])
  @@map("reimbursements")
}

// Horas extra (§6-3.3). Reusa el patron de reembolsos.
model OvertimeRequest {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation("OvertimeRequester", fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Float
  reason      String
  status      FinanceStatus @default(PENDIENTE)
  decidedById String?
  decidedBy   User?         @relation("OvertimeApprover", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, status])
  @@map("overtime_requests")
}

// Liquidacion de sueldo (§6-3.4). Una por colaborador y periodo (mes).
model Liquidation {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("UserLiquidations", fields: [userId], references: [id], onDelete: Cascade)
  period       String // "2026-06" (mes)
  fileUrl      String // PDF en StorageService
  uploadedById String?
  createdAt    DateTime @default(now())

  @@unique([userId, period])
  @@index([userId])
  @@map("liquidations")
}

// ============ OPERACIONES (Etapa 4) ============

enum TaskStatus {
  PENDIENTE
  EN_PROGRESO
  REVISADO
  COMPLETADO
}

model Task {
  id              String     @id @default(cuid())
  name            String
  description     String?
  status          TaskStatus @default(PENDIENTE)
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedToId    String?
  assignedTo      User?      @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User       @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  estimatedPoints Int        @default(0)
  actualPoints    Int?
  recurrence      String?    // cron expression para tareas cíclicas
  clientUserId    String?    // ITO/cliente que solicitó la tarea
  clientUser      User?      @relation("TaskClientRequester", fields: [clientUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([projectId, status])
  @@index([assignedToId])
  @@map("tasks")
}

enum ProjectDocumentStatus {
  BORRADOR
  PENDIENTE_QA
  PENDIENTE_CLIENTE
  APROBADO
  RECHAZADO
}

model ProjectDocument {
  id              String                @id @default(cuid())
  name            String
  code            String                @unique // formato: GMT-{Client}-{Depto}-{Project}-{Service}-{TipoDoc}-{Area}-{No}
  fileUrl         String
  fileHash        String?               // hash SHA-256 para integridad (FES)
  status          ProjectDocumentStatus @default(BORRADOR)
  version         Int                   @default(0) // rev0 = 0, revA = 1, etc.
  previousFileUrl String?
  projectId       String
  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  ownerId         String
  owner           User                  @relation("ProjectDocumentOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  qaSignerId      String?
  qaSigner        User?                 @relation("DocumentQASigner", fields: [qaSignerId], references: [id], onDelete: SetNull)
  qaSignedAt      DateTime?
  clientSignerId  String?
  clientSigner    User?                 @relation("DocumentClientSigner", fields: [clientSignerId], references: [id], onDelete: SetNull)
  clientSignedAt  DateTime?
  rejectionReason String?               // motivo de rechazo si aplica
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([projectId, status])
  @@index([serviceId])
  @@map("project_documents")
}

// ============ RECURSOS / ACTIVOS (Etapa 5) ============
// Base reutilizable de Equipo (5.2) y Vehículo (5.3) — primitiva `AssetBase` (§5):
// codificación automática, QR/ficha pública, documentos (ApprovalWorkflow),
// historial y disputa "en uso".

enum AssetType {
  EQUIPO
  VEHICULO
}

enum AssetStatus {
  DISPONIBLE
  EN_USO
  MANTENIMIENTO
  BAJA
}

model Asset {
  id           String      @id @default(cuid())
  code         String      @unique // codificación automática; identifica el activo en el QR / ficha pública
  type         AssetType
  name         String
  description  String?
  status       AssetStatus @default(DISPONIBLE)
  // Pertenencia opcional a un proyecto (FGA asset.project → can_view_list / can_create).
  projectId    String?
  project      Project?    @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: SetNull)
  // Responsable que corre el checklist (FGA asset.assigned → can_run_checklist).
  assignedToId String?
  assignedTo   User?       @relation("AssignedAssets", fields: [assignedToId], references: [id], onDelete: SetNull)
  // Disputa "en uso": quién lo tiene tomado y desde cuándo.
  inUseById    String?
  inUseBy      User?       @relation("InUseAssets", fields: [inUseById], references: [id], onDelete: SetNull)
  inUseSince   DateTime?
  // Campos específicos por subtipo (ciclos de carga/calibración en equipos; km/ubicación en vehículos).
  metadata     Json?
  documents    AssetDocument[]
  history      AssetHistoryEntry[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([type, status])
  @@map("assets")
}

// Documentos del activo (ApprovalWorkflow §5): versionado + revisor. Reusa
// `DocumentStatus` (BORRADOR/EN_REVISION/APROBADO/RECHAZADO) como los docs personales.
model AssetDocument {
  id              String         @id @default(cuid())
  assetId         String
  asset           Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  name            String
  type            String
  fileUrl         String
  status          DocumentStatus @default(EN_REVISION)
  previousFileUrl String?
  reviewedById    String?
  reviewedBy      User?          @relation("AssetDocReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([assetId])
  @@map("asset_documents")
}

// Historial de eventos del activo (creación, asignación, uso/liberación, docs, checklist, cambios de estado).
model AssetHistoryEntry {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type        String // CREADO | ASIGNADO | EN_USO | LIBERADO | DOC | CHECKLIST | ESTADO | OTRO
  description String
  actorId     String?
  actor       User?    @relation("AssetHistoryActor", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([assetId, createdAt])
  @@map("asset_history")
}
