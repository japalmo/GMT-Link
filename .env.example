# ── GMT Link — Variables de entorno (plantilla) ──────────────────────────────
# Copia este archivo como ".env" en la raíz. El .env real NUNCA se commitea.

# Base de datos (PostgreSQL local — WSL Ubuntu o docker compose)
DATABASE_URL="postgresql://gmt_admin:gmt_dev_2024@localhost:5432/gmt_link"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenFGA (§2, §4.3 del plan maestro)
FGA_API_URL="http://localhost:8080"
FGA_STORE_ID=""
FGA_MODEL_ID=""

# Firebase Auth (§2)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
# DEV: enruta firebase-admin al emulador local (firebase-admin lee esta var solo).
# En producción debe quedar VACÍA/ausente. En dev: localhost:9099
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# Storage — Cloudflare R2 (§2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="gmt-link-docs"

# IA — NVIDIA NIM (OpenAI-compatible), reemplaza a Gemini. Cuota 3/día/usuario (§2).
# Texto (limpiador de datos en Proveedores) y Visión (detección de costa en Herramientas).
NVIDIA_API_KEY=""
NVIDIA_API_KEY_VISION=""
# Overrides opcionales de modelo (tienen default en el código):
# NVIDIA_TEXT_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
# NVIDIA_VISION_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning"

# API
PORT=3001
NODE_ENV=development
# Orígenes permitidos para CORS (lista separada por comas). En dev cae a
# http://localhost:5173 si se omite. En Railway/prod: la URL pública del frontend,
# p. ej. CORS_ORIGINS="https://gmt-link-web.up.railway.app"
CORS_ORIGINS="http://localhost:5173"

# Frontend (Vite expone solo VITE_*)
VITE_API_URL="http://localhost:3001"

# Firebase Auth — cliente web (Etapa 0.5). En DEV apuntamos al emulador local,
# por eso la API key puede ser cualquier valor ("demo"). connectAuthEmulator se
# activa solo si VITE_FIREBASE_AUTH_EMULATOR está definida; déjala VACÍA en prod.
VITE_FIREBASE_API_KEY="demo"
VITE_FIREBASE_AUTH_DOMAIN="demo-gmt-link.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="demo-gmt-link"
VITE_FIREBASE_AUTH_EMULATOR="http://localhost:9099"
