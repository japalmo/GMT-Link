# ── GMT Link — Variables de entorno (plantilla) ──────────────────────────────
# Copia este archivo como ".env" en la raíz. El .env real NUNCA se commitea.

# Base de datos (PostgreSQL local — WSL Ubuntu o docker compose)
DATABASE_URL="postgresql://gmt_admin:gmt_dev_2024@localhost:5432/gmt_link"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenFGA (§2, §4.3 del plan maestro)
FGA_API_URL="http://localhost:8080"
FGA_STORE_ID=""
FGA_MODEL_ID=""

# Storage — Cloudflare R2 (§2). isR2Configured() exige las 5; si falta una, cae a storage local.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="gmt-link-docs"
R2_ENDPOINT=""            # p. ej. https://<accountid>.r2.cloudflarestorage.com
# Opcionales (tienen default en el código): R2_PRESIGN_TTL_SECONDS, STORAGE_MAX_BYTES

# IA — NVIDIA NIM (OpenAI-compatible), reemplaza a Gemini. Cuota 3/día/usuario (§2).
# Texto (limpiador de datos en Proveedores) y Visión (detección de costa en Herramientas).
NVIDIA_API_KEY=""
NVIDIA_API_KEY_VISION=""
# Overrides opcionales de modelo (tienen default en el código):
# NVIDIA_TEXT_MODEL="nvidia/nemotron-3-ultra-550b-a55b"
# NVIDIA_VISION_MODEL="nvidia/nemotron-3-nano-omni-30b-a3b-reasoning"

# API
PORT=3001
NODE_ENV=development
# Orígenes permitidos para CORS (lista separada por comas). En dev cae a
# http://localhost:5173 si se omite. En Railway/prod: la URL pública del frontend,
# p. ej. CORS_ORIGINS="https://gmt-link-web.up.railway.app"
CORS_ORIGINS="http://localhost:5173"

# Admin seed. Si se omite, el seed genera una clave aleatoria y la imprime una vez.
# En prod deja al admin en PENDING_FIRST_LOGIN (fuerza cambio en el primer login);
# en dev el admin queda ACTIVE (no fuerza cambio).
ADMIN_PASSWORD=""

# Email (SMTP) — DESACTIVADO por defecto. Si SMTP_HOST está vacío se usa
# NoopEmailService (no se envían correos). Se activa en Fase 3 con plantilla acordada.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="no-reply@gmt.cl"

# Frontend (Vite expone solo VITE_*)
VITE_API_URL="http://localhost:3001"
