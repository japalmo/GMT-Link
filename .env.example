# ── GTM Link — Variables de entorno (plantilla) ──────────────────────────────
# Copia este archivo como ".env" en la raíz. El .env real NUNCA se commitea.

# Base de datos (PostgreSQL local — WSL Ubuntu o docker compose)
DATABASE_URL="postgresql://gmt_admin:gmt_dev_2024@localhost:5432/gtm_link"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenFGA (§2, §4.3 del plan maestro)
FGA_API_URL="http://localhost:8080"
FGA_STORE_ID=""
FGA_MODEL_ID=""

# Firebase Auth (§2)
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# Storage — Cloudflare R2 (§2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="gtm-link-docs"

# IA — Gemini desde backend, cuota 3/día/usuario (§2)
GEMINI_API_KEY=""

# API
PORT=3001
NODE_ENV=development

# Frontend (Vite expone solo VITE_*)
VITE_API_URL="http://localhost:3001"
